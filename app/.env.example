# 30 Days English — frontend env (copy to .env.local and fill in).
# Leave blank to keep the app as a pure offline PWA (browser voice, no AI, no login).

# Cloudflare Worker base URL — AI proxy (Claude) + Azure Speech token + auth (/me,/login).
# e.g. https://thirty-days-en.<your-subdomain>.workers.dev
# (or "/api" if you route the Worker under the same domain via Cloudflare Pages)
VITE_WORKER_URL=

# Optional: Azure neural voice name (default en-US-AvaMultilingualNeural).
VITE_AZURE_VOICE=
