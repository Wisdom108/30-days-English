# 30 Days English — frontend env (copy to .env.local and fill in).
# Leave any blank to keep that premium feature off; the app still runs as a
# pure offline PWA (browser voice, no AI, no login).

# Cloudflare Worker base URL — AI proxy (Claude) + Azure Speech token minting.
# e.g. https://thirty-days-en.<your-subdomain>.workers.dev
VITE_WORKER_URL=

# Supabase project (Auth + progress/quota). Public anon key is safe to expose.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Optional: Azure neural voice name (default en-US-AvaMultilingualNeural).
VITE_AZURE_VOICE=
